", "verticalAlign": "top", "containerId": null, "originalText": "Virtual Ring", "autoResize": true, "lineHeight": 1.25}, {"id": "PS8dShV04va5wLk1UTt32", "type": "text", "x": 3858.498487353136, "y": 28135.722447147888, "width": 674.3877563476562, "height": 135, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "#a5d8ff", "fillStyle": "solid", "strokeWidth": 4, "strokeStyle": "solid", "roughness": 2, "opacity": 90, "groupIds": [], "frameId": null, "index": "bTX", "roundness": null, "seed": 2000724033, "version": 229, "versionNonce": 1795914817, "isDeleted": false, "boundElements": [], "updated": 1777637999884, "link": null, "locked": false, "text": "Virtual Nodes\nEach server appears multiple \ntimes on the ring -> even Load sharing", "fontSize": 36, "fontFamily": 5, "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "Virtual Nodes\nEach server appears multiple \ntimes on the ring -> even Load sharing", "autoResize": true, "lineHeight": 1.25}, {"id": "mrWu7hcu4nsDB7qWEVFeY", "type": "text", "x": 2309.2569220298915, "y": 28388.910065746546, "width": 717.9735107421875, "height": 151.03692520676483, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "#a5d8ff", "fillStyle": "solid", "strokeWidth": 4, "strokeStyle": "solid", "roughness": 2, "opacity": 90, "groupIds": [], "frameId": null, "index": "bTY", "roundness": null, "seed": 127735425, "version": 340, "versionNonce": 934562849, "isDeleted": false, "boundElements": [], "updated": 1777637999884, "link": null, "locked": false, "text": "\nNaive Hashing: 75% keys Move\nConsistent Hashing:  ~1/N key moves", "fontSize": 40.276513388470626, "fontFamily": 5, "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "\nNaive Hashing: 75% keys Move\nConsistent Hashing:  ~1/N key moves", "autoResize": true, "lineHeight": 1.25}, {"id": "jwNciUbVoYJ1iOQ773dA8", "type": "text", "x": 2327.2984628875015, "y": 28218.12147419137, "width": 542.9252053974612, "height": 20